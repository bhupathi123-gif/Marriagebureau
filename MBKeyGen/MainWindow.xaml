<Window x:Class="MBKeyGen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Marriage Bureau – Key Generator"
        Height="740" Width="660"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Style="{StaticResource MaterialDesignWindow}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#4A148C" Padding="24,18">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔑" FontSize="32" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel>
                        <TextBlock Text="Marriage Bureau Key Generator"
                                   FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Generate encrypted security codes and business name tokens"
                                   FontSize="12" Foreground="#CE93D8" Margin="0,2"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══ Main Content ════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20,24,24">

                <!-- ── Tab-style section selector ────────────────── -->
                <TabControl Style="{StaticResource MaterialDesignTabControl}"
                            Margin="0,0,0,20">

                    <!-- ═══════════ TAB 1: Security Code ═════════════ -->
                    <TabItem Header="Security Code Generator">
                        <StackPanel Margin="0,20,0,0">

                            <!-- Business Name input -->
                            <materialDesign:Card Padding="20" UniformCornerRadius="10"
                                                 Margin="0,0,0,16"
                                                 materialDesign:ElevationAssist.Elevation="Dp2">
                                <StackPanel>
                                    <TextBlock Text="Step 1 – Enter Business Details"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#4A148C" Margin="0,0,0,14"/>

                                    <TextBlock Text="Business Name"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="#5E35B1" Margin="0,0,0,4"/>
                                    <TextBox x:Name="BusinessNameBox"
                                             materialDesign:HintAssist.Hint="e.g. Sri Lakshmi Marriage Bureau"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             Margin="0,0,0,16"
                                             TextChanged="OnInputChanged"/>

                                    <TextBlock Text="Expiry Date"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="#5E35B1" Margin="0,0,0,4"/>
                                    <DatePicker x:Name="ExpiryDatePicker"
                                                materialDesign:HintAssist.Hint="Select expiry date"
                                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                                Margin="0,0,0,8"
                                                SelectedDateChanged="OnInputChanged"/>

                                    <!-- Quick date buttons -->
                                    <WrapPanel Margin="0,0,0,4">
                                        <TextBlock Text="Quick set: " Foreground="Gray"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Margin="0,0,8,0"/>
                                        <Button x:Name="Btn3M" Content="+3 Months"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Height="28" Padding="10,0" FontSize="11"
                                                Margin="0,0,6,0" Click="QuickDate_Click"/>
                                        <Button x:Name="Btn6M" Content="+6 Months"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Height="28" Padding="10,0" FontSize="11"
                                                Margin="0,0,6,0" Click="QuickDate_Click"/>
                                        <Button x:Name="Btn1Y" Content="+1 Year"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Height="28" Padding="10,0" FontSize="11"
                                                Margin="0,0,6,0" Click="QuickDate_Click"/>
                                        <Button x:Name="Btn2Y" Content="+2 Years"
                                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Height="28" Padding="10,0" FontSize="11"
                                                Click="QuickDate_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </materialDesign:Card>

                            <!-- Generate button -->
                            <Button x:Name="GenerateCodeBtn"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Background="#4A148C" Height="48"
                                    FontSize="15" Margin="0,0,0,16"
                                    Click="GenerateCode_Click">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Key" Width="22" Height="22"
                                                             Margin="0,0,10,0"/>
                                    <TextBlock Text="Generate Security Code" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Output section -->
                            <materialDesign:Card Padding="20" UniformCornerRadius="10"
                                                 materialDesign:ElevationAssist.Elevation="Dp2">
                                <StackPanel>
                                    <TextBlock Text="Step 2 – Copy the Generated Code"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#4A148C" Margin="0,0,0,14"/>

                                    <TextBlock Text="Security Code (encrypted)"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="#5E35B1" Margin="0,0,0,4"/>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="SecurityCodeOutputBox"
                                                 Grid.Column="0"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Courier New"
                                                 FontSize="11"
                                                 Background="#F3E5F5"
                                                 materialDesign:HintAssist.Hint="Generated code will appear here"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Margin="0,0,8,0"
                                                 MinHeight="80"/>
                                        <Button Grid.Column="1" VerticalAlignment="Top"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Copy to clipboard"
                                                Click="CopySecurityCode_Click">
                                            <materialDesign:PackIcon Kind="ContentCopy"/>
                                        </Button>
                                    </Grid>

                                    <TextBlock Text="Encrypted Business Name (for DB)"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="#5E35B1" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="EncryptedNameOutputBox"
                                                 Grid.Column="0"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Courier New"
                                                 FontSize="11"
                                                 Background="#F3E5F5"
                                                 materialDesign:HintAssist.Hint="Encrypted name will appear here"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Margin="0,0,8,0"/>
                                        <Button Grid.Column="1" VerticalAlignment="Top"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Copy to clipboard"
                                                Click="CopyEncryptedName_Click">
                                            <materialDesign:PackIcon Kind="ContentCopy"/>
                                        </Button>
                                    </Grid>

                                    <!-- Status -->
                                    <Border x:Name="CodeStatusBorder" CornerRadius="6"
                                            Padding="12,8" Margin="0,12,0,0"
                                            Background="#E8F5E9">
                                        <TextBlock x:Name="CodeStatusText"
                                                   Text="Enter details and click Generate."
                                                   Foreground="#2E7D32"
                                                   TextWrapping="Wrap" FontSize="12"/>
                                    </Border>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </TabItem>

                    <!-- ═══════════ TAB 2: Validate Code ══════════════ -->
                    <TabItem Header="Validate / Decode Code">
                        <StackPanel Margin="0,20,0,0">
                            <materialDesign:Card Padding="20" UniformCornerRadius="10"
                                                 Margin="0,0,0,16"
                                                 materialDesign:ElevationAssist.Elevation="Dp2">
                                <StackPanel>
                                    <TextBlock Text="Validate a Security Code"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#4A148C" Margin="0,0,0,14"/>
                                    <TextBlock Text="Paste an existing security code to verify it and view its contents."
                                               FontSize="11" Foreground="Gray" Margin="0,0,0,12"/>

                                    <TextBlock Text="Security Code" FontWeight="SemiBold"
                                               FontSize="12" Foreground="#5E35B1" Margin="0,0,0,4"/>
                                    <TextBox x:Name="ValidateCodeBox"
                                             materialDesign:HintAssist.Hint="Paste security code here"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             TextWrapping="Wrap" MinHeight="80"
                                             FontFamily="Courier New" FontSize="11"
                                             Margin="0,0,0,12"
                                             TextChanged="ValidateCode_Changed"/>

                                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                            Background="#1565C0" Height="44"
                                            Click="ValidateCode_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="ShieldCheck"
                                                                     Width="20" Height="20"
                                                                     Margin="0,0,10,0"/>
                                            <TextBlock Text="Validate Code" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Validation result -->
                                    <Border x:Name="ValidateBorder" CornerRadius="8"
                                            Padding="14,10" Margin="0,16,0,0"
                                            Background="#F5F5F5">
                                        <StackPanel>
                                            <StackPanel x:Name="ValidateResultPanel" Visibility="Collapsed">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="160"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition/>
                                                        <RowDefinition/>
                                                        <RowDefinition/>
                                                        <RowDefinition/>
                                                    </Grid.RowDefinitions>

                                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                                               Text="Status:" FontWeight="SemiBold"
                                                               FontSize="12" Margin="0,4"/>
                                                    <TextBlock x:Name="ValStatusText"
                                                               Grid.Row="0" Grid.Column="1"
                                                               FontSize="12" Margin="0,4"
                                                               FontWeight="Bold"/>

                                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                                               Text="Business Name:" FontWeight="SemiBold"
                                                               FontSize="12" Margin="0,4"/>
                                                    <TextBlock x:Name="ValBizNameText"
                                                               Grid.Row="1" Grid.Column="1"
                                                               FontSize="12" Margin="0,4"/>

                                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                                               Text="Expiry Date:" FontWeight="SemiBold"
                                                               FontSize="12" Margin="0,4"/>
                                                    <TextBlock x:Name="ValExpiryText"
                                                               Grid.Row="2" Grid.Column="1"
                                                               FontSize="12" Margin="0,4"/>

                                                    <TextBlock Grid.Row="3" Grid.Column="0"
                                                               Text="Message:" FontWeight="SemiBold"
                                                               FontSize="12" Margin="0,4"/>
                                                    <TextBlock x:Name="ValMessageText"
                                                               Grid.Row="3" Grid.Column="1"
                                                               FontSize="12" Margin="0,4"
                                                               TextWrapping="Wrap"/>
                                                </Grid>
                                            </StackPanel>
                                            <TextBlock x:Name="ValidatePlaceholderText"
                                                       Text="Validation result will appear here."
                                                       Foreground="Gray" FontSize="12"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </TabItem>

                    <!-- ═══════════ TAB 3: Password Hash ══════════════ -->
                    <TabItem Header="Password Hash Generator">
                        <StackPanel Margin="0,20,0,0">
                            <materialDesign:Card Padding="20" UniformCornerRadius="10"
                                                 materialDesign:ElevationAssist.Elevation="Dp2">
                                <StackPanel>
                                    <TextBlock Text="Generate Password Hash for App Users"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#4A148C" Margin="0,0,0,14"/>
                                    <TextBlock TextWrapping="Wrap" FontSize="11"
                                               Foreground="Gray" Margin="0,0,0,12">
                                        Use this to create a PBKDF2-SHA256 password hash for
                                        inserting a user directly into the database.
                                        The hash format is "HASH:SALT" (Base64).
                                    </TextBlock>

                                    <TextBlock Text="Password" FontWeight="SemiBold"
                                               FontSize="12" Foreground="#5E35B1" Margin="0,0,0,4"/>
                                    <PasswordBox x:Name="PwdBox"
                                                 materialDesign:HintAssist.Hint="Enter password to hash"
                                                 Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                                 Margin="0,0,0,12"/>

                                    <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                            Background="#2E7D32" Height="44"
                                            Click="HashPassword_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Lock"
                                                                     Width="20" Height="20"
                                                                     Margin="0,0,10,0"/>
                                            <TextBlock Text="Hash Password" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- Hash output -->
                                    <TextBlock Text="Generated Hash (copy to database PasswordHash column):"
                                               FontWeight="SemiBold" FontSize="12"
                                               Foreground="#5E35B1" Margin="0,16,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="HashOutputBox"
                                                 Grid.Column="0"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Courier New"
                                                 FontSize="10"
                                                 Background="#E8F5E9"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Margin="0,0,8,0"
                                                 MinHeight="60"/>
                                        <Button Grid.Column="1" VerticalAlignment="Top"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Copy hash to clipboard"
                                                Click="CopyHash_Click">
                                            <materialDesign:PackIcon Kind="ContentCopy"/>
                                        </Button>
                                    </Grid>

                                    <TextBlock x:Name="HashStatusText" Margin="0,8,0,0"
                                               FontSize="11" Foreground="#2E7D32"/>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </TabItem>

                    <!-- ═══════════ TAB 4: Encrypt / Decrypt ══════════ -->
                    <TabItem Header="Encrypt / Decrypt Text">
                        <StackPanel Margin="0,20,0,0">
                            <materialDesign:Card Padding="20" UniformCornerRadius="10"
                                                 materialDesign:ElevationAssist.Elevation="Dp2">
                                <StackPanel>
                                    <TextBlock Text="Encrypt or Decrypt Any Text"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="#4A148C" Margin="0,0,0,14"/>

                                    <TextBlock Text="Input Text" FontWeight="SemiBold"
                                               FontSize="12" Foreground="#5E35B1" Margin="0,0,0,4"/>
                                    <TextBox x:Name="EncDecInputBox"
                                             materialDesign:HintAssist.Hint="Enter text to encrypt or decrypt"
                                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                             TextWrapping="Wrap" MinHeight="80"
                                             Margin="0,0,0,12"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Style="{StaticResource MaterialDesignRaisedButton}"
                                                Background="#4A148C" Margin="0,0,12,0" Height="40"
                                                Click="Encrypt_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="LockOutline"
                                                                         Margin="0,0,8,0"/>
                                                <TextBlock Text="Encrypt"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                                                Height="40" Click="Decrypt_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="LockOpenOutline"
                                                                         Margin="0,0,8,0"/>
                                                <TextBlock Text="Decrypt"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>

                                    <TextBlock Text="Output" FontWeight="SemiBold"
                                               FontSize="12" Foreground="#5E35B1" Margin="0,0,0,4"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="EncDecOutputBox"
                                                 Grid.Column="0"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 FontFamily="Courier New"
                                                 FontSize="11"
                                                 Background="#F3E5F5"
                                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                                 Margin="0,0,8,0"
                                                 MinHeight="80"/>
                                        <Button Grid.Column="1" VerticalAlignment="Top"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                ToolTip="Copy to clipboard"
                                                Click="CopyEncDec_Click">
                                            <materialDesign:PackIcon Kind="ContentCopy"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </materialDesign:Card>
                        </StackPanel>
                    </TabItem>

                </TabControl>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══ Footer ════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#4A148C" Padding="16,8">
            <TextBlock Text="Marriage Bureau Key Generator  •  For admin use only  •  Keep this tool secure"
                       Foreground="#CE93D8" FontSize="10"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
