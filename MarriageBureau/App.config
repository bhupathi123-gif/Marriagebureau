<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="DataRootPath" value="E:\MatrimoneyDataTest"/>
    <add key="BgImagePath" value="E:\MatrimoneyDataTest\Template\TS_gbimage.jfif"/>
    <add key="ProfileIdPrefix" value="TM99"/>

    <!-- ── PDF / Image Export Layout ──────────────────────────────────── -->
    <!-- Name banner font size (pt) -->
    <add key="Export.NameFontSize" value="24"/>
    <!-- ProfileId / IntId sub-header font size (pt) -->
    <add key="Export.IdFontSize" value="11"/>
    <!-- Section heading font size for single-column layout (pt) -->
    <add key="Export.SectionHeadingFontSize_1Col" value="14"/>
    <!-- Field label/value font size for single-column layout (pt) -->
    <add key="Export.FieldFontSize_1Col" value="14"/>
    <!-- Section heading font size for two-column layout (pt) -->
    <add key="Export.SectionHeadingFontSize_2Col" value="12"/>
    <!-- Field label/value font size for two-column layout (pt) -->
    <add key="Export.FieldFontSize_2Col" value="12"/>
    <!-- Number of non-empty fields threshold to switch to two-column layout -->
    <add key="Export.TwoColThreshold" value="17"/>
    <!-- Label column width (pt) in single-column layout -->
    <add key="Export.LabelWidth_1Col" value="120"/>
    <!-- Label column width (pt) in two-column layout -->
    <add key="Export.LabelWidth_2Col" value="95"/>
  </appSettings>
</configuration>