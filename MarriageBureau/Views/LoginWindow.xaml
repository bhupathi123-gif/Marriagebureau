<Window x:Class="MarriageBureau.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:converters="clr-namespace:MarriageBureau.Converters"
        Title="Marriage Bureau – Login"
        Height="580" Width="430"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#4A148C"
        TextElement.Foreground="White"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Style="{StaticResource MaterialDesignWindow}">

    <Window.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Inverts a bool for IsEnabled: licence expired → button disabled -->
        <converters:InverseBoolConverter       x:Key="InvertBool"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Top Logo / Title ═════════════════════════════════════ -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,36,0,24">
            <TextBlock Text="💍" FontSize="52" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding BusinessName}" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="White"
                       TextWrapping="Wrap" TextAlignment="Center" Margin="20,6,20,0"/>
            <TextBlock Text="Management System" FontSize="13" Foreground="#CE93D8"
                       HorizontalAlignment="Center" Margin="0,2"/>
        </StackPanel>

        <!-- ═══ Login Card ════════════════════════════════════════════ -->
        <materialDesign:Card Grid.Row="1" Margin="32,0,32,0"
                             UniformCornerRadius="12"
                             materialDesign:ElevationAssist.Elevation="Dp8"
                             Padding="28,24">
            <StackPanel>

                <!-- Licence expired banner -->
                <Border Background="#FFEBEE" CornerRadius="8" Padding="12,8" Margin="0,0,0,16"
                        Visibility="{Binding IsLicenceExpired, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AlertCircle" Foreground="Crimson"
                                                 Width="20" Height="20" Margin="0,0,8,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LicenceMessage}" Foreground="Crimson"
                                   FontSize="11" TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Licence warning (valid but showing a message, not expired) -->
                <Border Background="#FFF8E1" CornerRadius="8" Padding="12,8" Margin="0,0,0,16">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <!-- Show only when licence is NOT expired but there IS a message -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLicenceExpired}" Value="False"/>
                                        <Condition Binding="{Binding HasLicenceWarning}"  Value="True"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding LicenceMessage}" Foreground="#E65100"
                               FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <!-- Username -->
                <TextBlock Text="Username" FontWeight="SemiBold" FontSize="12"
                           Foreground="#5E35B1" Margin="0,0,0,4"/>
                <TextBox x:Name="UsernameBox"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Enter username"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,0,16"/>

                <!-- Password -->
                <TextBlock Text="Password" FontWeight="SemiBold" FontSize="12"
                           Foreground="#5E35B1" Margin="0,0,0,4"/>
                <PasswordBox x:Name="PasswordBox"
                             materialDesign:HintAssist.Hint="Enter password"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             Margin="0,0,0,8"
                             PasswordChanged="PasswordBox_PasswordChanged"/>

                <!-- Error message -->
                <Border Background="#FFEBEE" CornerRadius="6" Padding="10,6" Margin="0,4,0,12"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Crimson"
                               FontSize="11" TextWrapping="Wrap"/>
                </Border>

                <!-- Login button — disabled when licence is expired -->
                <Button x:Name="LoginBtn"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#4A148C" Height="44" IsDefault="True"
                        IsEnabled="{Binding IsLicenceExpired, Converter={StaticResource InvertBool}}">
                    <Grid Width="200">
                        <ProgressBar IsIndeterminate="True" Height="4"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource MaterialDesignLinearProgressBar}"
                                     Visibility="{Binding IsLoggingIn, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Sign In"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoggingIn}" Value="True">
                                            <Setter Property="Text" Value="Signing in…"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Button>

            </StackPanel>
        </materialDesign:Card>

        <!-- ═══ Footer ════════════════════════════════════════════════ -->
        <TextBlock Grid.Row="2" Text="© 2025 Marriage Bureau Management System"
                   HorizontalAlignment="Center" Foreground="#CE93D8"
                   FontSize="10" Margin="0,16,0,20"/>
    </Grid>
</Window>
