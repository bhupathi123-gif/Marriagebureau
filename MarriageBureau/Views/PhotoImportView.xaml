<Page x:Class="MarriageBureau.Views.PhotoImportView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:MarriageBureau.Converters"
      Background="{DynamicResource MaterialDesignPaper}"
      Title="Import Photos">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ImportStatusColorConverter x:Key="StatusColor"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header Bar ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#1A237E" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ImageMultiple" Width="28" Height="28"
                                                 Foreground="#90CAF9" Margin="0,0,10,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Import Profile Photos" FontSize="22"
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <TextBlock FontSize="12" Foreground="#90CAF9" Margin="38,2,0,0"
                               TextWrapping="Wrap">
                        Bulk-import photos for existing profiles.
                        Source folder: rootPath\&lt;IntId&gt;\ or rootPath\&lt;IntId&gt;_1.jpg, etc.
                        Photos saved as: IntId_1.ext, IntId_2.ext, …
                    </TextBlock>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="White" BorderBrush="White">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Margin="0,0,6,0"/>
                        <TextBlock Text="Back"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Path Selection + Options ════════════════════════════ -->
        <materialDesign:Card Grid.Row="1" Padding="20,16" Margin="16,12,16,0"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1 – Path + browse + scan -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding SourcePath, Mode=OneWay}"
                             IsReadOnly="True"
                             materialDesign:HintAssist.Hint="Select root folder containing profile photos"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="1" Command="{Binding BrowseFolderCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOpen" Margin="0,0,6,0"/>
                            <TextBlock Text="Select Folder…"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Command="{Binding ScanCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#1565C0"
                            IsEnabled="{Binding PathSelected}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Magnify" Margin="0,0,6,0"/>
                            <TextBlock Text="Scan for Photos"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Row 2 – Options -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,14,0,0">
                    <CheckBox Content="Skip profiles that already have photos"
                              IsChecked="{Binding SkipExisting}"
                              Foreground="{DynamicResource MaterialDesignBody}"
                              Margin="0,0,24,0"/>
                    <CheckBox Content="Overwrite existing photos"
                              IsChecked="{Binding OverwriteExisting}"
                              Foreground="{DynamicResource MaterialDesignBody}"
                              Margin="0,0,24,0"/>
                    <materialDesign:Card Background="#E3F2FD" Padding="8,6" UniformCornerRadius="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Information" Foreground="#1565C0"
                                                     Width="16" Height="16" Margin="0,0,6,0"
                                                     VerticalAlignment="Center"/>
                            <TextBlock FontSize="11" Foreground="#0D47A1" VerticalAlignment="Center">
                                Supported: rootPath\IntId\*.jpg  |  rootPath\IntId_1.jpg  |  rootPath\IntId.jpg
                            </TextBlock>
                        </StackPanel>
                    </materialDesign:Card>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- ═══ Preview Table ════════════════════════════════════════ -->
        <materialDesign:Card Grid.Row="2" Padding="0" Margin="16,10,16,0"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sub-header -->
                <Border Grid.Row="0" Background="#E3F2FD" Padding="14,8" CornerRadius="8,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ImageMultiple" Foreground="#1565C0"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#0D47A1">
                                <Run Text="Profile Photo Scan — "/>
                                <Run Text="{Binding TotalRows, Mode=OneWay}"/>
                                <Run Text=" profiles"/>
                            </TextBlock>
                        </StackPanel>
                        <!-- Stats -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#2E7D32" CornerRadius="4" Padding="8,3" Margin="4,0">
                                <TextBlock Foreground="White" FontSize="12">
                                    <Run Text="✓ Imported: "/>
                                    <Run Text="{Binding ImportedCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#F57F17" CornerRadius="4" Padding="8,3" Margin="4,0">
                                <TextBlock Foreground="White" FontSize="12">
                                    <Run Text="⏭ Skipped: "/>
                                    <Run Text="{Binding SkippedCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#C62828" CornerRadius="4" Padding="8,3" Margin="4,0">
                                <TextBlock Foreground="White" FontSize="12">
                                    <Run Text="✗ Errors: "/>
                                    <Run Text="{Binding ErrorCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Loading overlay -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="300" Height="6"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                    <TextBlock Text="Scanning folder…" HorizontalAlignment="Center"
                               Margin="0,12" FontSize="14"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                        <Condition Binding="{Binding PathSelected}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="ImageMultiple" Width="80" Height="80"
                                             Foreground="#90CAF9" HorizontalAlignment="Center"/>
                    <TextBlock Text="No folder selected" FontSize="20" FontWeight="SemiBold"
                               Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                    <TextBlock TextAlignment="Center" Foreground="Gray" TextWrapping="Wrap" MaxWidth="500">
                        Click "Select Folder…" to choose the root folder that contains profile photos.
                        Photos should be organised as:  rootPath\IntId\photos   or   rootPath\IntId_1.jpg
                    </TextBlock>
                </StackPanel>

                <!-- Data Grid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Rows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          materialDesign:DataGridAssist.CellPadding="8,5"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">

                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TotalRows}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Setter Property="Height" Value="38"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="IntId"      Binding="{Binding IntId}"               Width="70"/>
                        <DataGridTextColumn Header="ProfileId"  Binding="{Binding ProfileId}"           Width="80"/>
                        <DataGridTextColumn Header="Name"       Binding="{Binding Name}"                Width="*" MinWidth="160"/>
                        <DataGridTextColumn Header="Has Photo"  Binding="{Binding HasExistingPhoto}"    Width="75"/>
                        <DataGridTextColumn Header="# Photos"   Binding="{Binding PhotoCount}"          Width="65"/>
                        <DataGridTextColumn Header="Matched Files" Binding="{Binding MatchedPhotoDisplay}" Width="*" MinWidth="200"/>

                        <!-- Status column with colour -->
                        <DataGridTemplateColumn Header="Status" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="{Binding Status, Converter={StaticResource StatusColor}}">
                                        <TextBlock Text="{Binding Status}" Foreground="White"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Note" Binding="{Binding ErrorMessage}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- ═══ Bottom Action Bar ════════════════════════════════════ -->
        <materialDesign:Card Grid.Row="3" Padding="16,10" Margin="16,8,16,12"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status message -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding StatusMessage}"
                               FontSize="12" Foreground="{DynamicResource MaterialDesignBody}"
                               TextWrapping="Wrap" MaxWidth="700"/>
                </StackPanel>

                <!-- Importing progress + buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,14,0"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}"/>

                    <Button Command="{Binding ClearCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Close" Margin="0,0,6,0"/>
                            <TextBlock Text="Clear"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ImportPhotosCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#1A237E">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ImagePlus" Margin="0,0,6,0"/>
                            <TextBlock Text="Import Photos to Database"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
