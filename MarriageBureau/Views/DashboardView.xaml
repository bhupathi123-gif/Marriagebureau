<Page x:Class="MarriageBureau.Views.DashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:MarriageBureau.Converters"
      Background="{DynamicResource MaterialDesignPaper}"
      Title="Dashboard">

    <Page.Resources>
        <converters:PathToImageConverter x:Key="PathToImageConverter"/>
        <converters:GenderToColorConverter x:Key="GenderToColorConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">

            <!-- Header -->
            <TextBlock Text="Dashboard" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryHueMidBrush}" Margin="0,0,0,6"/>
            <TextBlock Text="Welcome to Marriage Bureau Management System"
                       FontSize="14" Foreground="Gray" Margin="0,0,0,24"/>

            <!-- Stat Cards Row -->
            <UniformGrid Columns="5" Margin="0,0,0,24">

                <!-- Total -->
                <materialDesign:Card Margin="4" Padding="16"
                    UniformCornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="36" Height="36"
                                                 Foreground="#4A148C" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalProfiles}" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="#4A148C"/>
                        <TextBlock Text="Total Profiles" FontSize="12" Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Male -->
                <materialDesign:Card Margin="4" Padding="16"
                    UniformCornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="GenderMale" Width="36" Height="36"
                                                 Foreground="SteelBlue" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding MaleProfiles}" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="SteelBlue"/>
                        <TextBlock Text="Male" FontSize="12" Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Female -->
                <materialDesign:Card Margin="4" Padding="16"
                    UniformCornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="GenderFemale" Width="36" Height="36"
                                                 Foreground="DeepPink" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FemaleProfiles}" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="DeepPink"/>
                        <TextBlock Text="Female" FontSize="12" Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- With Photos -->
                <materialDesign:Card Margin="4" Padding="16"
                    UniformCornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="Camera" Width="36" Height="36"
                                                 Foreground="DarkOrange" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding WithPhotos}" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="DarkOrange"/>
                        <TextBlock Text="With Photos" FontSize="12" Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- With PDFs -->
                <materialDesign:Card Margin="4" Padding="16"
                    UniformCornerRadius="12"
                    materialDesign:ElevationAssist.Elevation="Dp3">
                    <StackPanel HorizontalAlignment="Center">
                        <materialDesign:PackIcon Kind="FilePdfBox" Width="36" Height="36"
                                                 Foreground="Crimson" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding WithPdfs}" FontSize="36" FontWeight="Bold"
                                   HorizontalAlignment="Center" Foreground="Crimson"/>
                        <TextBlock Text="With PDFs" FontSize="12" Foreground="Gray"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </materialDesign:Card>
            </UniformGrid>

            <!-- Quick Action Buttons -->
            <TextBlock Text="Quick Actions" FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>
            <WrapPanel Margin="0,0,0,24">
                <Button Command="{Binding AddNewCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#4A148C" Margin="0,0,12,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" Margin="0,0,8,0"/>
                        <TextBlock Text="Add New Biodata"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding BrowseCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,12,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountSearch" Margin="0,0,8,0"/>
                        <TextBlock Text="Browse Profiles"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding SlideshowCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,12,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Slideshow" Margin="0,0,8,0"/>
                        <TextBlock Text="View Slideshow"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!-- Recent Profiles -->
            <TextBlock Text="Recently Added Profiles" FontSize="18" FontWeight="SemiBold"
                       Margin="0,0,0,12"/>
            <materialDesign:Card UniformCornerRadius="8" Padding="0"
                                 materialDesign:ElevationAssist.Elevation="Dp2">
                <DataGrid ItemsSource="{Binding RecentProfiles}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          materialDesign:DataGridAssist.CellPadding="8,6"
                          MaxHeight="350"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="S.No" Binding="{Binding Id}" Width="55"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" MinWidth="150"/>
                        <DataGridTextColumn Header="Gender" Binding="{Binding Gender}" Width="80"/>
                        <DataGridTextColumn Header="Caste" Binding="{Binding Caste}" Width="120"/>
                        <DataGridTextColumn Header="Date of Birth" Binding="{Binding DateOfBirth}" Width="120"/>
                        <DataGridTextColumn Header="Qualification" Binding="{Binding Qualification}" Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="Phone 1" Binding="{Binding Phone1}" Width="120"/>
                        <DataGridTextColumn Header="District" Binding="{Binding District}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>
        </StackPanel>
    </ScrollViewer>
</Page>
