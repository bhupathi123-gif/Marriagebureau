<Page x:Class="MarriageBureau.Views.BrowseView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:MarriageBureau.Converters"
      Background="{DynamicResource MaterialDesignPaper}"
      Title="Browse Profiles">

    <Page.Resources>
        <converters:PathToImageConverter x:Key="PathToImage"/>
        <converters:GenderToColorConverter x:Key="GenderColor"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:PhotoFallbackConverter x:Key="PhotoFallback"/>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══════════════════════════════════════════════ -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Browse Profiles" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                <TextBlock FontSize="13" Foreground="Gray">
                    <Run Text="{Binding FilteredCount, Mode=OneWay}"/>
                    <Run Text="of"/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    <Run Text="profiles shown"/>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,8,0" ToolTip="Refresh">
                    <materialDesign:PackIcon Kind="Refresh"/>
                </Button>
                <Button Command="{Binding ImportExcelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,8,0" ToolTip="Import profiles from Excel file"
                        Foreground="#2E7D32" BorderBrush="#2E7D32">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExcel" Margin="0,0,8,0"/>
                        <TextBlock Text="Import Excel"/>
                    </StackPanel>
                </Button>
                <!--<Button Command="{Binding ImportPhotosCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,8,0" ToolTip="Bulk-import photos for existing profiles (by IntId)"
                        Foreground="#1A237E" BorderBrush="#1A237E">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ImageMultiple" Margin="0,0,8,0"/>
                        <TextBlock Text="Import Photos"/>
                    </StackPanel>
                </Button>-->
                <Button Command="{Binding ExportExcelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Margin="0,0,8,0"
                        ToolTip="Export current filtered profiles to Excel"
                        Foreground="#1565C0" BorderBrush="#1565C0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExcelOutline" Margin="0,0,8,0"/>
                        <TextBlock Text="Export Excel"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding AddNewCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#4A148C">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" Margin="0,0,8,0"/>
                        <TextBlock Text="Add New"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ═══ Search / Filter Bar ══════════════════════════════════ -->
        <materialDesign:Card Grid.Row="1" Padding="12" Margin="0,0,0,12"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="🔍  Search by IntId, profile ID, name, phone, caste, district..."
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,8,0"/>

                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding GenderOptions}"
                          SelectedItem="{Binding GenderFilter}"
                          materialDesign:HintAssist.Hint="Gender"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,8,0"/>

                <TextBox Grid.Column="2"
                         Text="{Binding CasteFilter, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Filter by Caste"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Margin="0,0,8,0"/>

                <ComboBox Grid.Column="3"
                          ItemsSource="{Binding StatusOptions}"
                          SelectedItem="{Binding StatusFilter}"
                          materialDesign:HintAssist.Hint="Status"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Margin="0,0,8,0"/>

                <Button Grid.Column="4" Command="{Binding ClearSearchCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        ToolTip="Clear Filters">
                    <materialDesign:PackIcon Kind="FilterRemove"/>
                </Button>
            </Grid>
        </materialDesign:Card>

        <!-- ═══ Data Grid ════════════════════════════════════════════ -->
        <materialDesign:Card Grid.Row="2" Padding="0" UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <!-- Loading indicator -->
                <ProgressBar IsIndeterminate="True"
                             VerticalAlignment="Top"
                             Height="4"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"/>

                <DataGrid x:Name="ProfileGrid"
                          ItemsSource="{Binding FilteredProfiles}"
                          SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          materialDesign:DataGridAssist.CellPadding="8,5"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          MouseDoubleClick="ProfileGrid_MouseDoubleClick">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Setter Property="Height" Value="42"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="IntId"      Binding="{Binding IntId}"     Width="70"/>
                        <DataGridTextColumn Header="ProfileId"  Binding="{Binding ProfileId}" Width="80"/>

                        <!-- Photo column -->
                        <DataGridTemplateColumn Header="Photo" Width="54">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="38" Height="38" CornerRadius="19"
                                            ClipToBounds="True" Margin="2">
                                        <Border.Background>
                                            <SolidColorBrush Color="#EDE7F6"/>
                                        </Border.Background>
                                        <Image Source="{Binding PrimaryPhotoPath, Converter={StaticResource PhotoFallback}}"
                                               Stretch="UniformToFill"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Name"        Binding="{Binding Name}"          Width="*" MinWidth="140"/>
                        <DataGridTextColumn Header="Gender"      Binding="{Binding Gender}"         Width="80"/>
                        <DataGridTextColumn Header="Caste"       Binding="{Binding Caste}"          Width="120"/>
                        <DataGridTextColumn Header="D.O.B"       Binding="{Binding DateOfBirth}"    Width="100"/>
                        <DataGridTextColumn Header="Age"         Binding="{Binding AgeDisplay}"     Width="60"/>
                        <DataGridTextColumn Header="Height"      Binding="{Binding Height}"         Width="75"/>
                        <DataGridTextColumn Header="Qualification" Binding="{Binding Qualification}" Width="*" MinWidth="130"/>
                        <DataGridTextColumn Header="Birth Star"  Binding="{Binding BirthStar}"     Width="90"/>
                        <DataGridTextColumn Header="Raasi"       Binding="{Binding Raasi}"          Width="90"/>
                        <DataGridTextColumn Header="District"    Binding="{Binding District}"       Width="110"/>
                        <DataGridTextColumn Header="Phone"       Binding="{Binding Phone1}"         Width="115"/>

                        <!-- Status column with coloured badge -->
                        <DataGridTemplateColumn Header="Status" Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="8" Padding="6,2" Margin="2"
                                            Background="{Binding StatusColor}">
                                        <TextBlock Text="{Binding StatusDisplay}"
                                                   Foreground="White" FontSize="10"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- PDF indicator -->
                        <DataGridTemplateColumn Header="PDF" Width="48">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <materialDesign:PackIcon Kind="FilePdfBox"
                                        Foreground="Crimson"
                                        HorizontalAlignment="Center"
                                        Visibility="{Binding HasPdf, Converter={StaticResource BoolToVis}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- ═══ Bottom Action Bar ════════════════════════════════════ -->
        <!--<materialDesign:Card Grid.Row="3" Padding="10,8" Margin="0,10,0,0"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Information" Foreground="Gray" Margin="0,0,6,0"/>
                    <TextBlock Foreground="Gray" FontSize="12">
                        <Run Text="Double-click to edit a profile. Selected: "/>
                        <Run Text="{Binding SelectedProfile.Name, TargetNullValue='None', Mode=OneWay}"
                             FontWeight="SemiBold"/>
                    </TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding EditCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,8,0">
