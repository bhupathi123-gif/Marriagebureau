<Page x:Class="MarriageBureau.Views.ExcelImportView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:MarriageBureau.Converters"
      Background="{DynamicResource MaterialDesignPaper}"
      Title="Import from Excel">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:ImportStatusColorConverter x:Key="StatusColor"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Header Bar ═══════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#4A148C" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExcel" Width="28" Height="28"
                                                 Foreground="#A5D6A7" Margin="0,0,10,0"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="Import Biodata from Excel" FontSize="22"
                                   FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <TextBlock Text="Supports the standard biodata Excel format with MALE and FEMALE sheets"
                               FontSize="12" Foreground="#A5D6A7" Margin="38,2,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding CancelCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="White" BorderBrush="White">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowLeft" Margin="0,0,6,0"/>
                        <TextBlock Text="Back"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ File Selection + Options ════════════════════════════ -->
        <materialDesign:Card Grid.Row="1" Padding="20,16" Margin="16,12,16,0"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 1 – File path + browse + parse -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding FilePath, Mode=OneWay}"
                             IsReadOnly="True"
                             materialDesign:HintAssist.Hint="Select an Excel file (.xlsx) to import"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Margin="0,0,10,0"/>

                    <Button Grid.Column="1" Command="{Binding BrowseFileCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FolderOpen" Margin="0,0,6,0"/>
                            <TextBlock Text="Browse…"/>
                        </StackPanel>
                    </Button>

                    <Button Grid.Column="2" Command="{Binding ParsePreviewCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#2E7D32"
                            IsEnabled="{Binding FileSelected}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Eye" Margin="0,0,6,0"/>
                            <TextBlock Text="Preview Data"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Row 2 – Options -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,12,0,0">
                    <CheckBox Content="Skip duplicate names (recommended)"
                              IsChecked="{Binding SkipDuplicates}"
                              Foreground="{DynamicResource MaterialDesignBody}"
                              Margin="0,0,24,0"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <materialDesign:PackIcon Kind="Information" Foreground="#2E7D32"
                                                 Margin="0,0,6,0" Width="16" Height="16"/>
                        <TextBlock Text="Excel sheets named MALE / FEMALE are automatically detected"
                                   FontSize="11" Foreground="Gray" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </materialDesign:Card>

        <!-- ═══ Preview Table ════════════════════════════════════════ -->
        <materialDesign:Card Grid.Row="2" Padding="0" Margin="16,10,16,0"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sub-header -->
                <Border Grid.Row="0" Background="#E8F5E9" Padding="14,8" CornerRadius="8,8,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="TableLarge" Foreground="#2E7D32"
                                                     Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#1B5E20">
                                <Run Text="Preview — "/>
                                <Run Text="{Binding TotalRows, Mode=OneWay}"/>
                                <Run Text=" records found"/>
                            </TextBlock>
                        </StackPanel>
                        <!-- Stats after import -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Background="#2E7D32" CornerRadius="4" Padding="8,3" Margin="4,0">
                                <TextBlock Foreground="White" FontSize="12">
                                    <Run Text="✓ Imported: "/>
                                    <Run Text="{Binding ImportedCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#F57F17" CornerRadius="4" Padding="8,3" Margin="4,0">
                                <TextBlock Foreground="White" FontSize="12">
                                    <Run Text="⏭ Skipped: "/>
                                    <Run Text="{Binding SkippedCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                            <Border Background="#C62828" CornerRadius="4" Padding="8,3" Margin="4,0">
                                <TextBlock Foreground="White" FontSize="12">
                                    <Run Text="✗ Errors: "/>
                                    <Run Text="{Binding ErrorCount, Mode=OneWay}"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Loading overlay -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <ProgressBar IsIndeterminate="True" Width="300" Height="6"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                    <TextBlock Text="Reading Excel file…" HorizontalAlignment="Center"
                               Margin="0,12" FontSize="14"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="40">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsLoading}" Value="False"/>
                                        <Condition Binding="{Binding FileSelected}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="FileExcelOutline" Width="80" Height="80"
                                             Foreground="#A5D6A7" HorizontalAlignment="Center"/>
                    <TextBlock Text="No file selected" FontSize="20" FontWeight="SemiBold"
                               Foreground="#2E7D32" HorizontalAlignment="Center" Margin="0,12,0,6"/>
                    <TextBlock TextAlignment="Center" Foreground="Gray" TextWrapping="Wrap" MaxWidth="420">
                        Click "Browse…" to select the standard biodata Excel file.
                        The file should contain sheets named MALE and FEMALE with the standard column headers.
                    </TextBlock>
                </StackPanel>

                <!-- Data Grid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding PreviewRows}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserSortColumns="True"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          materialDesign:DataGridAssist.CellPadding="8,5"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          BorderThickness="0"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">

                    <DataGrid.Style>
                        <Style TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding TotalRows}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.Style>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                            <Setter Property="Height" Value="38"/>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"          Binding="{Binding RowNum}"        Width="45"/>
                        <DataGridTextColumn Header="Name"       Binding="{Binding Name}"          Width="*" MinWidth="150"/>
                        <DataGridTextColumn Header="Gender"     Binding="{Binding Gender}"        Width="72"/>
                        <DataGridTextColumn Header="Caste"      Binding="{Binding Caste}"         Width="110"/>
                        <DataGridTextColumn Header="D.O.B"      Binding="{Binding DateOfBirth}"   Width="100"/>
                        <DataGridTextColumn Header="Height"     Binding="{Binding Height}"        Width="72"/>
                        <DataGridTextColumn Header="Qualification" Binding="{Binding Qualification}" Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="Designation"   Binding="{Binding Designation}"   Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="District"   Binding="{Binding District}"      Width="110"/>
                        <DataGridTextColumn Header="Phone"      Binding="{Binding Phone1}"        Width="115"/>
                        <DataGridTextColumn Header="Birth Star" Binding="{Binding BirthStar}"     Width="90"/>
                        <DataGridTextColumn Header="Raasi"      Binding="{Binding Raasi}"         Width="80"/>

                        <!-- Status column with colour -->
                        <DataGridTemplateColumn Header="Status" Width="140">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="4" Padding="6,2"
                                            Background="{Binding Status, Converter={StaticResource StatusColor}}">
                                        <TextBlock Text="{Binding Status}" Foreground="White"
                                                   FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTextColumn Header="Note" Binding="{Binding ErrorMessage}" Width="180"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </materialDesign:Card>

        <!-- ═══ Bottom Action Bar ════════════════════════════════════ -->
        <materialDesign:Card Grid.Row="3" Padding="16,10" Margin="16,8,16,12"
                             UniformCornerRadius="8"
                             materialDesign:ElevationAssist.Elevation="Dp1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Status message -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Information" Foreground="#2E7D32"
                                             Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               FontSize="13" Foreground="{DynamicResource MaterialDesignBody}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Importing progress + buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="120" Height="4" Margin="0,0,14,0"
                                 Style="{StaticResource MaterialDesignLinearProgressBar}"
                                 Visibility="{Binding IsImporting, Converter={StaticResource BoolToVis}}"/>

                    <Button Command="{Binding ClearCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Margin="0,0,10,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Close" Margin="0,0,6,0"/>
                            <TextBlock Text="Clear"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding ImportCommand}"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#2E7D32">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="DatabaseImport" Margin="0,0,6,0"/>
                            <TextBlock Text="Import All to Database"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:Card>
    </Grid>
</Page>
