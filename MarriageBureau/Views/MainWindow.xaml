<Window x:Class="MarriageBureau.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Marriage Bureau - Management System"
        Height="820" Width="1280"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Style="{StaticResource MaterialDesignWindow}">

    <Window.Resources>
        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="NavButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Background" Value="#3D1E6B"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Left Navigation Panel ═══════════════════════════════════ -->
        <DockPanel Grid.Column="0" Background="#4A148C" LastChildFill="True">

            <!-- App Title -->
            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                <TextBlock Text="💍" FontSize="40" HorizontalAlignment="Center" Margin="0,20,0,5"/>
                <TextBlock Text="Marriage Bureau" Foreground="White"
                           FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           TextAlignment="Center" Margin="10,0"/>
                <TextBlock Text="Management System" Foreground="#CE93D8"
                           FontSize="11" HorizontalAlignment="Center"
                           Margin="10,2,10,15"/>
                <Separator Background="#7B1FA2"/>
            </StackPanel>

            <!-- Navigation Buttons -->
            <StackPanel DockPanel.Dock="Top" Margin="8,10">
                <Button x:Name="BtnDashboard"
                        Command="{Binding NavigateDashboardCommand}"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnBrowse"
                        Command="{Binding NavigateBrowseCommand}"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Browse Profiles" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnAdd"
                        Command="{Binding NavigateAddCommand}"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountPlus" Width="20" Height="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Add New Biodata" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnSlideshow"
                        Command="{Binding NavigateSlideshowCommand}"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Slideshow" Width="20" Height="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Profile Slideshow" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Separator Background="#7B1FA2" Margin="4,8"/>

                <Button x:Name="BtnImportExcel"
                        Command="{Binding NavigateExcelImportCommand}"
                        Style="{StaticResource NavButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FileExcel" Width="20" Height="20" Margin="0,0,12,0"/>
                        <TextBlock Text="Import from Excel" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Bottom Info -->
            <StackPanel DockPanel.Dock="Bottom" Margin="10,15">
                <Separator Background="#7B1FA2" Margin="0,0,0,10"/>
                <TextBlock Text="© 2025 Marriage Bureau" Foreground="#CE93D8"
                           FontSize="10" HorizontalAlignment="Center"/>
            </StackPanel>

            <Border/>
        </DockPanel>

        <!-- ═══ Main Content Area ════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"
                   Background="{DynamicResource MaterialDesignPaper}"/>
        </Grid>
    </Grid>
</Window>
