<Page x:Class="MarriageBureau.Views.SlideshowView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      xmlns:converters="clr-namespace:MarriageBureau.Converters"
      Background="#1a0533"
      Title="Profile Slideshow">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <converters:GenderToColorConverter x:Key="GenderColor"/>

        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CE93D8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,1"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- Nav arrow button style -->
        <Style x:Key="NavArrowStyle" TargetType="Button"
               BasedOn="{StaticResource MaterialDesignIconForegroundButton}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#55000000"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
        </Style>

        <!-- Filter label style -->
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CE93D8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,0,3"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Advanced filter panel (collapsible) -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Top Controls Bar ═════════════════════════════════════ -->
        <Border Grid.Row="0" Background="#2D0A4E" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Slideshow" Foreground="#CE93D8"
                                             Width="24" Height="24" Margin="0,0,8,0"/>
                    <TextBlock Text="Profile Slideshow" Foreground="White"
                               FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Gender filter + counter -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Gender: " Foreground="#CE93D8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox ItemsSource="{Binding GenderOptions}"
                              SelectedItem="{Binding GenderFilter}"
                              Foreground="White" Background="#4A148C"
                              BorderBrush="#7B1FA2"
                              Width="110"/>
                    <TextBlock Text="{Binding ProfileCounterText}" Foreground="#CE93D8"
                               VerticalAlignment="Center" Margin="16,0,0,0" FontSize="14"/>

                    <!-- Active filter badge -->
                    <Border Background="#F48FB1" CornerRadius="10" Padding="8,2" Margin="12,0,0,0"
                            Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Filters Active" Foreground="#880E4F"
                                   FontSize="11" FontWeight="Bold"/>
                    </Border>
                </StackPanel>

                <!-- Interval slider -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Interval: " Foreground="#CE93D8"
                               VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Slider Value="{Binding SlideIntervalSeconds}" Minimum="2" Maximum="30"
                            Width="90" VerticalAlignment="Center"
                            TickFrequency="1" IsSnapToTickEnabled="True"
                            Foreground="#CE93D8"/>
                    <TextBlock Text="{Binding SlideIntervalSeconds}" Foreground="White"
                               VerticalAlignment="Center" Margin="5,0,2,0" Width="20"/>
                    <TextBlock Text="s" Foreground="#CE93D8" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Filter toggle button -->
                <Button Grid.Column="3" Command="{Binding ToggleFilterPanelCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#CE93D8" ToolTip="Advanced Filters"
                        Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterVariant" Width="20" Height="20"/>
                        <TextBlock Text="Filters" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Refresh -->
                <Button Grid.Column="4" Command="{Binding RefreshCommand}"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Foreground="#CE93D8" ToolTip="Refresh">
                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20"/>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Advanced Filter Panel (collapsible) ══════════════════ -->
        <Border Grid.Row="1" Background="#3D1A5E" Padding="16,12"
                Visibility="{Binding FilterPanelOpen, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Caste filter -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock Text="Caste" Style="{StaticResource FilterLabel}"/>
                    <!--<ComboBox ItemsSource="{Binding CasteOptions}"
                              SelectedItem="{Binding CasteFilter}"
                              IsEditable="True"
                              Foreground="White" Background="#55000000"
                              BorderBrush="#7B1FA2"/>-->
                    <ComboBox ItemsSource="{Binding CasteOptions}"
              SelectedItem="{Binding CasteFilter}"
              IsEditable="True"
              Foreground="White"
              Background="#55000000"
              BorderBrush="#7B1FA2">

                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>

                    </ComboBox>
                </StackPanel>

                <!-- District filter -->
                <StackPanel Grid.Column="1" Margin="0,0,12,0">
                    <TextBlock Text="District" Style="{StaticResource FilterLabel}"/>
                    <ComboBox ItemsSource="{Binding DistrictOptions}"
                              SelectedItem="{Binding DistrictFilter}"
                             IsEditable="True"
  Foreground="White"
  Background="#55000000"
  BorderBrush="#7B1FA2">

                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>

                    </ComboBox>
                </StackPanel>

                <!-- Birth Star filter -->
                <StackPanel Grid.Column="2" Margin="0,0,12,0">
                    <TextBlock Text="Birth Star" Style="{StaticResource FilterLabel}"/>
                    <ComboBox ItemsSource="{x:Static vm:SlideshowViewModel.StarOptions}"
                              xmlns:vm="clr-namespace:MarriageBureau.ViewModels"
                              SelectedItem="{Binding StarFilter}"
                               IsEditable="True"
  Foreground="White"
  Background="#55000000"
  BorderBrush="#7B1FA2">

                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>

                    </ComboBox>
                </StackPanel>

                <!-- Raasi filter -->
                <StackPanel Grid.Column="3" Margin="0,0,12,0">
                    <TextBlock Text="Raasi" Style="{StaticResource FilterLabel}"/>
                    <ComboBox ItemsSource="{x:Static vm:SlideshowViewModel.RaasiOptions}"
                              xmlns:vm="clr-namespace:MarriageBureau.ViewModels"
                              SelectedItem="{Binding RaasiFilter}"
                                IsEditable="True"
  Foreground="White"
  Background="#55000000"
  BorderBrush="#7B1FA2">

                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="Padding" Value="5"/>
                                <Setter Property="FontSize" Value="13"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>

                    </ComboBox>
                </StackPanel>

                <!-- Age range -->
                <StackPanel Grid.Column="4" Margin="0,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Age: " Style="{StaticResource FilterLabel}"/>
                        <TextBlock Text="{Binding MinAge}" Foreground="White" FontSize="11" Margin="0,0,2,3"/>
                        <TextBlock Text=" – " Foreground="#CE93D8" FontSize="11" Margin="0,0,2,3"/>
                        <TextBlock Text="{Binding MaxAge}" Foreground="White" FontSize="11" Margin="0,0,0,3"/>
                    </StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0" Value="{Binding MinAge}" Minimum="18" Maximum="70"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#CE93D8" Margin="0,0,4,0"/>
                        <Slider Grid.Column="1" Value="{Binding MaxAge}" Minimum="18" Maximum="70"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#CE93D8"/>
                    </Grid>
                </StackPanel>

                <!-- Clear filters button -->
                <Button Grid.Column="5" Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#F48FB1" BorderBrush="#F48FB1"
                        VerticalAlignment="Bottom">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FilterRemove" Width="16" Height="16" Margin="0,0,4,0"/>
                        <TextBlock Text="Clear All"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══ Main Slide Content ═══════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- Loading state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             Style="{StaticResource MaterialDesignLinearProgressBar}"/>
                <TextBlock Text="Loading profiles…" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,12"/>
            </StackPanel>

            <!-- No profiles state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoading}" Value="False"/>
                                    <Condition Binding="{Binding HasCurrentProfile}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="AccountOff" Width="80" Height="80"
                                         Foreground="#CE93D8" HorizontalAlignment="Center"/>
                <TextBlock Text="No profiles found" Foreground="#CE93D8"
                           FontSize="24" HorizontalAlignment="Center" Margin="0,12"/>
                <TextBlock Text="Adjust your filters or add profiles to start the slideshow"
                           Foreground="#9E9E9E" HorizontalAlignment="Center"/>
                <Button Command="{Binding ClearFiltersCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="#CE93D8" BorderBrush="#CE93D8"
                        HorizontalAlignment="Center" Margin="0,12">
                    <TextBlock Text="Clear Filters"/>
                </Button>
            </StackPanel>

            <!-- Main Profile Slide -->
            <Grid Visibility="{Binding HasCurrentProfile, Converter={StaticResource BoolToVis}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="380"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Photo Area with per-profile slideshow -->
                <Grid Grid.Column="0" Margin="40,30,20,30">
                    <Border CornerRadius="20" ClipToBounds="True" Background="#2D0A4E">
                        <Grid>
                            <!-- Background gradient -->
                            <Rectangle>
                                <Rectangle.Fill>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#3D1E6B" Offset="0"/>
                                        <GradientStop Color="#1a0533" Offset="1"/>
                                    </LinearGradientBrush>
                                </Rectangle.Fill>
                            </Rectangle>

                            <!-- No photo placeholder -->
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPhoto}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasMultiplePhotos}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <materialDesign:PackIcon Kind="AccountCircle"
                                                         Width="160" Height="160"
                                                         Foreground="#4A148C"/>
                                <TextBlock Text="No Photo" Foreground="#7B1FA2"
                                           FontSize="18" HorizontalAlignment="Center"
                                           Margin="0,10"/>
                            </StackPanel>

                            <!-- Current photo of this profile -->
                            <Image Source="{Binding CurrentPhoto}"
                                   Stretch="Uniform"
                                   Margin="20">
                                <Image.Style>
                                    <Style TargetType="Image">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentPhoto}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Image.Style>
                            </Image>

                            <!-- Left/Right photo navigation (only if multiple photos) -->
                            <Grid Visibility="{Binding HasMultiplePhotos, Converter={StaticResource BoolToVis}}">
                                <Button HorizontalAlignment="Left" VerticalAlignment="Center"
                                        Command="{Binding PrevPhotoCommand}"
                                        Style="{StaticResource NavArrowStyle}"
                                        Margin="12">
                                    <materialDesign:PackIcon Kind="ChevronLeft" Width="22" Height="22"/>
                                </Button>
                                <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                                        Command="{Binding NextPhotoCommand}"
                                        Style="{StaticResource NavArrowStyle}"
                                        Margin="12">
                                    <materialDesign:PackIcon Kind="ChevronRight" Width="22" Height="22"/>
                                </Button>
                            </Grid>

                            <!-- Photo counter + dots overlay (top-right) -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Background="#88000000" CornerRadius="8" Padding="8,4"
                                    Margin="12"
                                    Visibility="{Binding HasMultiplePhotos, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding PhotoCounterText}"
                                           Foreground="White" FontSize="12"/>
                            </Border>

                            <!-- Name overlay at bottom -->
                            <Border VerticalAlignment="Bottom" CornerRadius="0,0,20,20"
                                    Padding="20,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CC000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="{Binding CurrentProfile.Name}"
                                               Foreground="White" FontSize="22"
                                               FontWeight="Bold" TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <Border CornerRadius="4" Padding="6,2" Margin="0,0,8,0"
                                                Background="{Binding CurrentProfile.Gender,
                                                    Converter={StaticResource GenderColor}}">
                                            <TextBlock Text="{Binding CurrentProfile.Gender}"
                                                       Foreground="White" FontSize="11"/>
                                        </Border>
                                        <TextBlock Text="{Binding CurrentProfile.AgeDisplay}"
                                                   Foreground="#CE93D8" FontSize="14"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Right: Details Panel -->
                <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                              Margin="0,20,30,20">
                    <StackPanel Margin="0,10">

                        <!-- Personal Details -->
                        <TextBlock Text="Personal Details" Foreground="#CE93D8"
                                   FontSize="13" FontWeight="Bold" Margin="0,0,0,10"
                                   Opacity="0.8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Date of Birth" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.DateOfBirth, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Height" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.Height, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Caste" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.Caste, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Complexion" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.Complexion, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Horoscope -->
                        <Separator Background="#4A148C" Margin="0,10"/>
                        <TextBlock Text="Horoscope" Foreground="#CE93D8"
                                   FontSize="13" FontWeight="Bold" Margin="0,4,0,10" Opacity="0.8"/>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Birth Star" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.BirthStar, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Padam" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.Padam, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Raasi" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.Raasi, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Paternal Gotram" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.PaternalGotram, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Maternal Gotram" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.MaternalGotram, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Education & Career -->
                        <Separator Background="#4A148C" Margin="0,10"/>
                        <TextBlock Text="Education &amp; Career" Foreground="#CE93D8"
                                   FontSize="13" FontWeight="Bold" Margin="0,4,0,10" Opacity="0.8"/>

                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Qualification" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding CurrentProfile.Qualification, TargetNullValue='N/A'}"
                                       Style="{StaticResource InfoValue}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Designation" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding CurrentProfile.Designation, TargetNullValue='N/A'}"
                                       Style="{StaticResource InfoValue}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,6">
                            <TextBlock Text="Company" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding CurrentProfile.CompanyAddress, TargetNullValue='N/A'}"
                                       Style="{StaticResource InfoValue}"/>
                        </StackPanel>

                        <!-- Family -->
                        <Separator Background="#4A148C" Margin="0,10"/>
                        <TextBlock Text="Family" Foreground="#CE93D8"
                                   FontSize="13" FontWeight="Bold" Margin="0,4,0,10" Opacity="0.8"/>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Father" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.FatherName, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                                <TextBlock Text="{Binding CurrentProfile.FatherOccupation, TargetNullValue=''}"
                                           Foreground="#CE93D8" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Mother" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.MotherName, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                                <TextBlock Text="{Binding CurrentProfile.MotherOccupation, TargetNullValue=''}"
                                           Foreground="#CE93D8" FontSize="11"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Brothers" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.BrotherCount, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Sisters" Style="{StaticResource InfoLabel}"/>
                                <TextBlock Text="{Binding CurrentProfile.SisterCount, TargetNullValue='N/A'}"
                                           Style="{StaticResource InfoValue}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Contact -->
                        <Separator Background="#4A148C" Margin="0,10"/>
                        <TextBlock Text="Contact" Foreground="#CE93D8"
                                   FontSize="13" FontWeight="Bold" Margin="0,4,0,10" Opacity="0.8"/>

                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="Phone 1" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding CurrentProfile.Phone1, TargetNullValue='N/A'}"
                                       Style="{StaticResource InfoValue}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="Phone 2" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Text="{Binding CurrentProfile.Phone2, TargetNullValue='N/A'}"
                                       Style="{StaticResource InfoValue}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,0,4">
                            <TextBlock Text="District / State" Style="{StaticResource InfoLabel}"/>
                            <TextBlock Style="{StaticResource InfoValue}">
                                <Run Text="{Binding CurrentProfile.District, TargetNullValue=''}"/>
                                <Run Text=","/>
                                <Run Text="{Binding CurrentProfile.State, TargetNullValue=''}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Expectations -->
                        <Separator Background="#4A148C" Margin="0,10"/>
                        <TextBlock Text="Partner Expectations" Foreground="#CE93D8"
                                   FontSize="13" FontWeight="Bold" Margin="0,4,0,6" Opacity="0.8"/>
                        <TextBlock Text="{Binding CurrentProfile.ExpectationsFromPartner, TargetNullValue='Not specified'}"
                                   Style="{StaticResource InfoValue}" Opacity="0.9"
                                   TextWrapping="Wrap" Margin="0,0,0,20"/>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- ═══ Bottom Playback Controls ═══════════════════════════ -->
        <Border Grid.Row="3" Background="#2D0A4E" Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Profile navigation -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            HorizontalAlignment="Left">
                    <TextBlock Text="Profile:" Foreground="#CE93D8" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontSize="12"/>
                    <Button Command="{Binding PreviousCommand}"
                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Foreground="#CE93D8" Width="36" Height="36"
                            ToolTip="Previous Profile">
                        <materialDesign:PackIcon Kind="SkipPrevious" Width="22" Height="22"/>
                    </Button>
                    <TextBlock Text="{Binding ProfileCounterText}" Foreground="White"
                               VerticalAlignment="Center" Margin="8,0" FontSize="13"/>
                    <Button Command="{Binding NextCommand}"
                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Foreground="#CE93D8" Width="36" Height="36"
                            ToolTip="Next Profile">
                        <materialDesign:PackIcon Kind="SkipNext" Width="22" Height="22"/>
                    </Button>
                </StackPanel>

                <!-- Play / Pause -->
                <Button Grid.Column="1"
                        Command="{Binding PlayPauseCommand}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#4A148C" Width="160" Height="44">
                    <TextBlock Text="{Binding PlayPauseLabel}" FontSize="15"/>
                </Button>

                <!-- Photo navigation (shown only if multiple photos on this profile) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Visibility="{Binding HasMultiplePhotos, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Photo:" Foreground="#CE93D8" VerticalAlignment="Center"
                               Margin="0,0,8,0" FontSize="12"/>
                    <Button Command="{Binding PrevPhotoCommand}"
                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Foreground="#CE93D8" Width="36" Height="36"
                            ToolTip="Previous Photo">
                        <materialDesign:PackIcon Kind="ChevronLeft" Width="20" Height="20"/>
                    </Button>
                    <TextBlock Text="{Binding PhotoCounterText}" Foreground="White"
                               VerticalAlignment="Center" Margin="6,0" FontSize="13"/>
                    <Button Command="{Binding NextPhotoCommand}"
                            Style="{StaticResource MaterialDesignIconForegroundButton}"
                            Foreground="#CE93D8" Width="36" Height="36"
                            ToolTip="Next Photo">
                        <materialDesign:PackIcon Kind="ChevronRight" Width="20" Height="20"/>
                    </Button>
                </StackPanel>

            </Grid>
        </Border>
    </Grid>
</Page>
